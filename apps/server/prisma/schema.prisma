generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  email         String    @unique
  passwordHash  String
  mmr           Int       @default(1000)
  rankTier      RankTier  @default(BRONZE)
  rankDivision  Int       @default(1)
  xp            Int       @default(0)
  coins         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  matches       MatchParticipant[]
  stats         PlayerStats?
  inventory     InventoryItem[]
  moderation    ModerationLog[]
}

model PlayerStats {
  id               String @id @default(uuid())
  userId           String @unique
  user             User   @relation(fields: [userId], references: [id])
  gamesPlayed      Int    @default(0)
  gamesWon         Int    @default(0)
  mafiaWins        Int    @default(0)
  villagerWins     Int    @default(0)
  policeAccuracy   Float  @default(0.0)
  doctorSaves      Int    @default(0)
  survivalRate     Float  @default(0.0)
}

model Match {
  id          String             @id @default(uuid())
  startTime   DateTime           @default(now())
  endTime     DateTime?
  mode        MatchMode
  winner      Role?              
  participants MatchParticipant[]
  events      MatchEvent[]
}

model MatchParticipant {
  id        String   @id @default(uuid())
  matchId   String
  userId    String
  role      Role
  isWinner  Boolean
  mmrChange Int
  match     Match    @relation(fields: [matchId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model MatchEvent {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id])
  timestamp DateTime @default(now())
  type      String
  data      Json
}

model InventoryItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  sku       String
  type      String
  isEquipped Boolean @default(false)
}

model ModerationLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  lobbyId   String
  reason    String
  riskScore Int
  metadata  Json
  createdAt DateTime @default(now())
}

enum RankTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
  ELITE
  MASTERMIND
  NIGHTFALL_LEGEND
}

enum MatchMode {
  CASUAL
  RANKED
}

enum Role {
  MAFIA
  POLICE
  DOCTOR
  VILLAGER
}
