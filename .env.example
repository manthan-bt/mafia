# --- SERVER CONFIG ---
PORT=3005
NODE_ENV=development

# --- AUTH & SECURITY ---
# Secret for signing JWT/Session tokens
AUTH_SECRET=your_super_secret_hmac_key_here
# Secret for internal service communication
INTERNAL_SERVICE_KEY=service_to_service_secret

# --- DATABASE (PostgreSQL) ---
# Used by Prisma
DB_USER=postgres
DB_PASSWORD=postgres_secure_password
DB_NAME=mafia
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}?schema=public"

# --- CACHE & REAL-TIME (Redis) ---
# Required for scaling Socket.io and rate limiting
REDIS_URL="redis://localhost:6379"

# --- EMAIL (SMTP) ---
# For OTP and account recovery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_FROM="Mafia Nightfall <noreply@mafia-game.com>"

# --- MONETIZATION ---
# Stripe/PayPal keys (if applicable)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
